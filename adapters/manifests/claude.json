{
  "schema_version": 1,
  "id": "claude",
  "name": "Claude",
  "detail": "Anthropic Claude CLI",
  "adapter_executable": "../bin/claude-adapter",
  "capabilities": ["session_resume"],
  "options": [
    {
      "key": "claude_model",
      "label": "MODEL",
      "values": ["default", "claude-fable-5", "claude-opus-4-8", "claude-sonnet-5", "claude-haiku-4-5-20251001"],
      "values_from": "claude_models",
      "default": "default"
    },
    {
      "key": "claude_effort",
      "label": "EFFORT",
      "values": ["default", "low", "medium", "high", "xhigh", "max"],
      "default": "default"
    }
  ],
  "requirements": [
    {
      "name": "Claude CLI",
      "environment": "RELAY_CLAUDE_PATH",
      "candidates": [
        "~/.local/bin/claude",
        "/opt/homebrew/bin/claude",
        "/usr/local/bin/claude"
      ],
      "version_arguments": ["--version"]
    }
  ]
}
